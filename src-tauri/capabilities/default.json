{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "local": true,
  "remote": {
    "urls": ["http://localhost:1430/**"]
  },
  "permissions": [
    "core:default",
    "opener:default",
    "deep-link:default",
    "store:default",
    "fs:default",
    "fs:write-all",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPCACHE/**" },
        { "path": "$HOME/**" }
      ]
    },
    "dialog:default",
    "sql:default",
    "sql:allow-execute",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://accounts.spotify.com/**" },
        { "url": "https://api.spotify.com/**" },
        { "url": "https://api.enchor.us/**" },
        { "url": "https://files.enchor.us/**" },
        { "url": "https://musical-artifacts.com/**" },
        { "url": "https://www.songsterr.com/**" },
        { "url": "https://gprotab.net/**" },
        { "url": "https://classclef.com/**" },
        { "url": "https://www.classclef.com/**" },
        { "url": "https://www.theguitarlesson.com/**" },
        { "url": "https://www.classtab.org/**" },
        { "url": "http://www.classtab.org/**" },
        { "url": "https://www.ultimate-guitar.com/**" },
        { "url": "https://tabs.ultimate-guitar.com/**" },
        { "url": "https://www.classicalguitarshed.com/**" },
        { "url": "https://imslp.org/**" },
        { "url": "https://ignition4.customsforge.com/**" },
        { "url": "https://customsforge.com/**" }
      ]
    }
  ]
}
