{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "deep-link:default",
    "store:default",
    "fs:default",
    "fs:write-all",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPCACHE/**" },
        { "path": "$HOME/**" }
      ]
    },
    "dialog:default",
    "sql:default",
    "sql:allow-execute",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://accounts.spotify.com/**" },
        { "url": "https://api.spotify.com/**" },
        { "url": "https://api.enchor.us/**" },
        { "url": "https://files.enchor.us/**" }
      ]
    }
  ]
}
